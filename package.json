{
  "name": "ExampleReactNativeAppUsedForTestingAnalytics",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "clean": "react-native clean",
    "ios:install": "cd ios && pod install",
    "start": "react-native start",
    "test": "jest",
    "onchange:body": "PACK=noibu-react-native-0.0.1.tgz;TO=./node_modules/noibu-react-native;rm -rf ${TO}/*;cp ./../unicron/public_sdk/react-native/${PACK} ${TO}/${PACK};tar -xzf ${TO}/${PACK} -C ${TO};mv ${TO}/package/* ${TO};rm -r ${TO}/package;echo \"Updating $(date +%s)\";",
    "onchange": "onchange -d 1000 \"./../unicron/public_sdk/react-native/noibu-react-native-0.0.1.tgz\" -- npm run onchange:body"
  },
  "dependencies": {
    "@react-native/metro-config": "^0.72.6",
    "noibu-react-native": "file:./../unicron/public_sdk/react-native/",
    "react": ">=16.11.0",
    "react-native": ">=0.63.0",
    "react-native-device-info": "^10.6.0",
    "react-native-url-polyfill": "^1.3.0",
    "react-native-uuid": "^2.0.1",
    "react-native-localize": "^3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@tsconfig/react-native": "^2.0.2",
    "@types/jest": "^29.2.1",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.73.9",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  },
  "jest": {
    "preset": "react-native"
  }
}
