  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "ios:install": "cd ios && pod install",
    "start": "react-native start",
    "test": "jest",
    "onchange:body": "SDK=./../unicron/public_sdk/react-native;D=./node_modules/noibu-react-native/; rm -rf ${D}/dist/;mkdir ${D}/dist;cp -R ${SDK}/dist/ ${D}/dist;cp $SDK/package.json ${D};echo \"Updating $(date +%s)\"",
